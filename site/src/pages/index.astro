---
import Layout from '../layouts/Layout.astro';

// ── Config ──────────────────────────────────────────────────────────────
// GTA 6 launch — confirmed by Take-Two ("no further delays" after two slips).
const LAUNCH_DATE = '2026-11-19T00:00:00Z';

// Email capture endpoint. Create a free form at https://formspree.io and paste
// its endpoint here (see site/README.md). While the placeholder stands, the
// form renders a "not configured" note and does not deliver.
const SUBSCRIBE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';
const SUBSCRIBE_CONFIGURED = !SUBSCRIBE_ENDPOINT.includes('YOUR_FORM_ID');

const REPO_URL = 'https://github.com/cfpperche/gta6-launch-playbook';

// ── Data ────────────────────────────────────────────────────────────────
const gta5Stats = [
  { num: '$800M', label: 'GTA 5 revenue in the first 24 hours (2013)' },
  { num: '$1B', label: 'reached in 3 days — fastest entertainment launch ever' },
  { num: '$10.2B+', label: 'generated by the franchise to date' },
  { num: '$1M/day', label: 'still earned by GTA Online in 2026' },
];

const gta6Stats = [
  { num: '$1.5B', label: 'development budget — the most expensive game ever made' },
  { num: '$2.7B', label: 'projected day-one revenue (analyst estimates)' },
  { num: '30M', label: 'projected day-one sales' },
];

const tiers = [
  {
    tag: 'Tier 1',
    title: 'Operate a business',
    blurb: 'Returns come from work and execution.',
    items: [
      { n: 1, name: 'Newsletter / Discord "alpha"', note: 'A paid information hub for GTA 6.' },
      { n: 2, name: 'Streaming', note: 'A streaming presence that compounds into the launch.' },
      { n: 3, name: 'UGC content factory', note: 'A high-volume short-form content operation.' },
      { n: 4, name: 'AI coaching & guides', note: 'The first data-driven guides at launch.' },
      { n: 5, name: 'In-game AI NPCs', note: 'Conversational NPC mod packs for servers.' },
      { n: 6, name: '"Picks & shovels"', note: 'The tools every creator and server needs.' },
      { n: 7, name: 'AI-powered RP server', note: 'A NoPixel-model roleplay server.' },
    ],
  },
  {
    tag: 'Tier 2',
    title: 'Allocate capital',
    blurb: 'Returns come from timing and risk. Tracked as observations — never advice.',
    items: [
      { n: 8, name: 'TTWO stock', note: 'A position in Take-Two ahead of launch.' },
      { n: 9, name: 'Gaming-crypto basket', note: 'Sector tokens on the GTA-6 narrative.' },
      { n: 10, name: 'GTA 6 memecoins', note: 'The explicit high-risk YOLO category.' },
      { n: 11, name: 'Streaming-infra crypto', note: 'Decentralized video / compute tokens.' },
      { n: 12, name: 'Web3 RP server', note: 'A roleplay server monetized with Web3.' },
    ],
  },
  {
    tag: 'Tier 3',
    title: 'Beyond the thread',
    blurb: 'Second-order and adjacent plays the source thread’s lens could not see.',
    items: [
      { n: 13, name: 'B2B intelligence product', note: 'An analyst desk for the GTA 6 economy.' },
      { n: 14, name: 'Trust & safety service', note: 'The trust layer for a noisy ecosystem.' },
      { n: 15, name: 'pt-BR-first hub', note: 'The Brazilian / LatAm GTA 6 hub.' },
      { n: 16, name: 'Post-hype consolidation', note: 'Acquire burned-out assets in 2027–28.' },
      { n: 17, name: 'Talent & labor layer', note: 'Staffing & training for the creator economy.' },
    ],
  },
];

const ceilings = [
  { n: 2, name: 'Streaming (AI-persona route)', ceiling: '~90%', core: 'Persona "soul"; platform ToS' },
  { n: 3, name: 'UGC content factory', ceiling: '~90%', core: 'Taste; strike handling' },
  { n: 6, name: '"Picks & shovels"', ceiling: '~88%', core: 'What-to-build judgment' },
  { n: 13, name: 'B2B intelligence product', ceiling: '~85%', core: 'B2B sales; credibility' },
  { n: 7, name: 'AI-powered RP server', ceiling: '~78%', core: 'Community leadership' },
  { n: 10, name: 'GTA 6 memecoins', ceiling: '~85% mech', core: 'Automation amplifies the loss' },
];

const milestones = [
  { date: '2026-05-21', label: 'Take-Two Q4 / FY2026 earnings call', conf: 'scheduled', note: 'Likely venue for a pre-order announcement.' },
  { date: '2026-05', label: 'GTA 6 pre-orders may open', conf: 'rumored', note: 'A leaked retailer window; unconfirmed.' },
  { date: 'Summer 2026', label: 'GTA 6 Trailer 3', conf: 'speculated', note: 'A major marketing inflection point.' },
  { date: '2026-11-19', label: 'GTA 6 launch — PS5, Xbox Series X|S', conf: 'confirmed', note: 'The anchor. "No further delays" per Take-Two.' },
  { date: 'Launch week', label: 'Metacritic reviews land', conf: '', note: 'The review band sets how long the wave lasts.' },
  { date: 'Mid-2027', label: 'GTA 6 PC release', conf: 'estimated', note: 'Following the GTA 5 pattern; gates #5, #7, #12.' },
];
---

<Layout
  title="GTA 6 Launch Playbook"
  description="An independent intelligence brief on the economy opening around the GTA 6 launch — 19 November 2026."
>
  <header class="site-header">
    <div>
      <span class="wordmark">GTA<span class="accent">6</span> · Launch Playbook</span>
      <a class="header-cta" href="#subscribe">Get the brief</a>
    </div>
  </header>

  <main>
    <!-- 1. Hero -->
    <section class="hero">
      <p class="eyebrow">Independent intelligence brief</p>
      <h1>The economy opening around <span class="accent">GTA&nbsp;6</span>.</h1>
      <p class="lede">
        The largest entertainment launch in history is months away. Around it, a
        five-year economy opens in a single day. This is the map — catalogued,
        evaluated, and tracked.
      </p>
      <div class="countdown" data-countdown>
        <div class="cd-unit"><span class="cd-num" data-days>—</span><span class="cd-label">days</span></div>
        <div class="cd-unit"><span class="cd-num" data-hours>—</span><span class="cd-label">hours</span></div>
        <div class="cd-unit"><span class="cd-num" data-minutes>—</span><span class="cd-label">minutes</span></div>
        <div class="cd-unit"><span class="cd-num" data-seconds>—</span><span class="cd-label">seconds</span></div>
      </div>
      <p class="countdown-cap">until launch · 19 November 2026</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#subscribe">Get the brief</a>
        <a class="btn btn-ghost" href={REPO_URL} target="_blank" rel="noopener">
          Read the full playbook →
        </a>
      </div>
    </section>

    <!-- 2. Thesis -->
    <section id="thesis" class="section">
      <h2><span class="sec-num">01</span> Why this exists</h2>
      <p class="section-intro">
        The magnitude of this launch is invisible from outside the games
        industry. The numbers are not.
      </p>

      <p class="stat-group-label">GTA 5 — the precedent</p>
      <div class="stat-grid">
        {gta5Stats.map((s) => (
          <div class="stat">
            <div class="stat-num">{s.num}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>

      <p class="stat-group-label">GTA 6 — the projection</p>
      <div class="stat-grid">
        {gta6Stats.map((s) => (
          <div class="stat">
            <div class="stat-num">{s.num}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>

      <p class="note">
        This is a planning workspace, not a get-rich-quick scheme. Every
        opportunity here is treated as a normal business or capital decision —
        with a real cost, a real downside, and an honest worst case.
      </p>
    </section>

    <!-- 3. Opportunity map -->
    <section id="map" class="section">
      <h2><span class="sec-num">02</span> The opportunity map</h2>
      <p class="section-intro">
        Seventeen opportunities in three tiers. Tiers 1–2 come from the source
        analysis; Tier 3 is what a structured look at its blind spots surfaced.
      </p>
      {tiers.map((tier) => (
        <div class="tier">
          <div class="tier-head">
            <span class="tier-tag">{tier.tag}</span>
            <span class="tier-title">{tier.title}</span>
          </div>
          <p class="tier-blurb">{tier.blurb}</p>
          <ul class="opp-list">
            {tier.items.map((item) => (
              <li class="opp">
                <span class="opp-n">{item.n}</span>
                <span class="opp-name">{item.name}</span>
                <span class="opp-note">{item.note}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <!-- 4. Automation lens -->
    <section id="automation" class="section">
      <h2><span class="sec-num">03</span> The automation lens</h2>
      <p class="section-intro">
        Each opportunity was assessed for how far AI can take its development and
        operation — with humans in the loop.
      </p>
      <div class="callout">
        The honest target is not "zero humans" — it is
        <strong>one operator supervising a fleet of AI agents</strong>. In the
        high-automation opportunities the production work disappears; what is
        left is judgment, accountability, and trust.
      </div>
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Opportunity</th>
            <th>Ceiling</th>
            <th>Irreducible human core</th>
          </tr>
        </thead>
        <tbody>
          {ceilings.map((row) => (
            <tr>
              <td class="mono">{row.n}</td>
              <td>{row.name}</td>
              <td class="mono">{row.ceiling}</td>
              <td>{row.core}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="note">
        For the capital plays (Tier 2), a high "automatable %" is a warning, not
        a feature — a bot executes a losing bet just as efficiently as a winning
        one.
      </p>
    </section>

    <!-- 5. Timeline -->
    <section id="timeline" class="section">
      <h2><span class="sec-num">04</span> The timeline</h2>
      <p class="section-intro">
        Every decision in the playbook is timed against one date. These are the
        milestones — and the signals — between now and launch.
      </p>
      <ul class="timeline">
        {milestones.map((m) => (
          <li class="tl-item">
            <span class="tl-date">{m.date}</span>
            <div>
              <span class="tl-label">{m.label}</span>
              {m.conf && <span class={`conf ${m.conf}`}>{m.conf}</span>}
              <p class="tl-note">{m.note}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- 6. Status -->
    <section id="status" class="section">
      <h2><span class="sec-num">05</span> Where it stands</h2>
      <p class="section-intro">
        Early, and built in the open. The opportunity catalogue and a first-pass
        evaluation are in place.
      </p>
      <div class="callout">
        Provisional front-runners on intrinsic merit:
        <strong>#13 — B2B intelligence product</strong> and
        <strong>#6 — "picks &amp; shovels"</strong>, both executable
        Portuguese-first. The full reasoning, scorecard, and per-opportunity
        automation briefs live in
        <a href={REPO_URL} target="_blank" rel="noopener">the public repository</a>.
      </div>
    </section>

    <!-- 7. Subscribe -->
    <section id="subscribe" class="section subscribe">
      <h2><span class="sec-num">06</span> Get the brief</h2>
      <p class="section-intro" style="margin-left:auto;margin-right:auto;">
        A periodic read on the GTA 6 economy — the timeline, the signals, and
        what is moving. No spam; unsubscribe anytime.
      </p>
      <form class="subscribe-form" action={SUBSCRIBE_ENDPOINT} method="POST">
        <input
          type="email"
          name="email"
          required
          placeholder="you@email.com"
          aria-label="Email address"
        />
        <button type="submit" class="btn btn-primary">Get the brief</button>
      </form>
      {!SUBSCRIBE_CONFIGURED && (
        <p class="form-note">
          Form endpoint not yet configured — see <code>site/README.md</code>.
        </p>
      )}
    </section>
  </main>

  <footer class="site-footer">
    <p class="disclaimer">
      This is a personal planning workspace, not financial advice. Opportunities
      involving public equity or crypto assets are tracked as observations only —
      no recommendation is made or implied. Not affiliated with, endorsed by, or
      connected to Rockstar Games or Take-Two Interactive.
    </p>
    <p>
      Built in the open ·
      <a href={REPO_URL} target="_blank" rel="noopener">github.com/cfpperche/gta6-launch-playbook</a>
    </p>
  </footer>

  <script define:vars={{ launchDate: LAUNCH_DATE }}>
    const target = new Date(launchDate).getTime();
    const el = {
      days: document.querySelector('[data-days]'),
      hours: document.querySelector('[data-hours]'),
      minutes: document.querySelector('[data-minutes]'),
      seconds: document.querySelector('[data-seconds]'),
    };
    const pad = (n) => String(n).padStart(2, '0');
    function tick() {
      const diff = target - Date.now();
      if (diff <= 0) {
        el.days.textContent = '0';
        el.hours.textContent = '00';
        el.minutes.textContent = '00';
        el.seconds.textContent = '00';
        return;
      }
      el.days.textContent = String(Math.floor(diff / 86400000));
      el.hours.textContent = pad(Math.floor((diff % 86400000) / 3600000));
      el.minutes.textContent = pad(Math.floor((diff % 3600000) / 60000));
      el.seconds.textContent = pad(Math.floor((diff % 60000) / 1000));
    }
    tick();
    setInterval(tick, 1000);
  </script>
</Layout>
